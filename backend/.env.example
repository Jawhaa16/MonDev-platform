# App Configuration
APP_NAME=MonDev.mn
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database Configuration
# SQLite for development (no PostgreSQL needed)
DATABASE_URL=sqlite+aiosqlite:///./mondev.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (Optional - can be configured later)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# QPay Configuration (Optional - can be configured later)
QPAY_USERNAME=your-qpay-username
QPAY_PASSWORD=your-qpay-password
QPAY_INVOICE_CODE=MONDEV_INVOICE
QPAY_API_URL=https://merchant.qpay.mn/v2

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload
MAX_FILE_SIZE=524288000
UPLOAD_DIR=./uploads

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0

# Platform Fee
PLATFORM_FEE_PERCENT=15
